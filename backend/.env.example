# ── EIA Open Data API ─────────────────────────────────────────────────────────
# Free key at https://www.eia.gov/opendata/register.php
EIA_API_KEY=your_eia_api_key_here
EIA_REGION=ERCO

# ── Africa's Talking SMS ──────────────────────────────────────────────────────
AT_API_KEY=your_africastalking_api_key_here
AT_USERNAME=sandbox
AT_SENDER_ID=ENERGY
AT_PHONE_NUMBERS=+250788000001,+250789000002

# ── Resend Email ──────────────────────────────────────────────────────────────
RESEND_API_KEY=re_your_resend_key_here
RESEND_FROM=alerts@yourdomain.com
RESEND_TO=admin@example.com,ops@example.com

# ── Webhook ───────────────────────────────────────────────────────────────────
WEBHOOK_SECRET=change-this-to-a-strong-random-secret
CONTROLLER_WEBHOOK_URL=http://localhost:8000/webhook/controller

# ── Thresholds ────────────────────────────────────────────────────────────────
LOAD_THRESHOLD_MW=20.0
